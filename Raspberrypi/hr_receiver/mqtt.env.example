# Copy this file to `mqtt.env` and fill in your HiveMQ Cloud credentials.
# hr_receiver.py and the systemd service both read these.
# Must match esp32/src/config.h.
MQTT_HOST=YOUR-CLUSTER.s1.eu.hivemq.cloud
MQTT_PORT=8883
MQTT_USER=YOUR_MQTT_USERNAME
MQTT_PASS=YOUR_MQTT_PASSWORD
MQTT_TOPIC=polar/hr
