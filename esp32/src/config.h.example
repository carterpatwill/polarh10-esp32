#pragma once

// Copy this file to `config.h` and fill in your own values.
// `config.h` is gitignored so your credentials never get committed.

// ── WiFi — personal network (tried first) ────────────────────────────────────
#define HOME_SSID      "YOUR_WIFI_SSID"
#define HOME_PASS      "YOUR_WIFI_PASSWORD"

// ── WiFi — second personal network (tried next) ──────────────────────────────
#define HOME2_SSID     "YOUR_SECOND_WIFI_SSID"
#define HOME2_PASS     "YOUR_SECOND_WIFI_PASSWORD"

// ── WiFi — phone hotspot (tried next) ────────────────────────────────────────
#define HOME3_SSID     "YOUR_HOTSPOT_SSID"
#define HOME3_PASS     "YOUR_HOTSPOT_PASSWORD"

// ── WiFi — WPA2-Enterprise / eduroam (fallback) ───────────────────────────────
// Leave as-is if you don't use an enterprise network.
#define ENT_SSID       "eduroam"
#define ENT_IDENTITY   "you@school.edu"
#define ENT_USER       "you@school.edu"
#define ENT_PASS       "YOUR_ENTERPRISE_PASSWORD"

// ── HiveMQ Cloud (MQTT broker) ───────────────────────────────────────────────
// Fill these from your HiveMQ Cloud console → "Cluster details" / "Access Management":
//   MQTT_HOST : the cluster URL, e.g. "abc123def.s1.eu.hivemq.cloud" (no https://)
//   MQTT_PORT : 8883 for TLS (HiveMQ Cloud requires TLS)
//   MQTT_USER : the username you created under Access Management → Credentials
//   MQTT_PASS : that credential's password
#define MQTT_HOST       "YOUR-CLUSTER.s1.eu.hivemq.cloud"
#define MQTT_PORT       8883
#define MQTT_USER       "YOUR_MQTT_USERNAME"
#define MQTT_PASS       "YOUR_MQTT_PASSWORD"
#define MQTT_TOPIC      "polar/hr"          // ESP32 publishes HR here, Pi subscribes here
#define MQTT_TOPIC_ACC  "polar/acc"         // ESP32 publishes accelerometer here
#define MQTT_TOPIC_PI      "pi/status"      // Pi publishes its heartbeat here, ESP32 subscribes
#define MQTT_TOPIC_SESSION "polar/session"  // ESP32 publishes session start/stop here, Pi subscribes
#define MQTT_TOPIC_ESP     "polar/esp_status"  // ESP32 publishes its live status here, control page subscribes
#define MQTT_TOPIC_CMD     "polar/session_cmd" // control page publishes start/stop here, ESP32 subscribes
#define MQTT_CLIENT_ID  "esp32-polar"

// Consider a Pi heartbeat "fresh" if seen within this many ms (heartbeat is every 5 s).
#define PI_FRESH_MS  15000

// How often the ESP32 publishes its status snapshot to MQTT_TOPIC_ESP (ms).
#define ESP_STATUS_MS  2000

// ── Board pins — Seeed Studio XIAO ESP32-S3 ──────────────────────────────────
// Onboard user LED is GPIO21 and is ACTIVE-LOW (driving LOW lights it): it
// blinks while connecting/scanning and lights solid once a Polar strap connects.
#define PIN_STATUS_LED  21

// The XIAO has no peripheral power-enable pin (the T-Display-S3 used GPIO15).
// Leave as -1 to skip. Set to a GPIO if your carrier board needs one driven high.
#define PIN_POWER_ON    -1

// ── Battery ───────────────────────────────────────────────────────────────────
// The XIAO ESP32-S3 does NOT route battery voltage to an ADC by default, so to
// read battery level you must wire BAT+ through a 1:2 divider (e.g. two equal
// resistors like 220k/220k) into one of the analog pins, then set PIN_BAT_ADC
// to that GPIO. Analog-capable pins:
//   A0=GPIO1  A1=GPIO2  A2=GPIO3  A3=GPIO4  A4=GPIO5  A5=GPIO6
//   A8=GPIO7  A9=GPIO8  A10=GPIO9
// Set PIN_BAT_ADC to -1 to disable battery reading (status reports -1 = unknown).
#define PIN_BAT_ADC  2    // A1 / D1 on XIAO — change to match your divider wiring

// ── Tuning ───────────────────────────────────────────────────────────────────
#define BATCH_MS   30000   // HR flush interval (ms)
#define QUEUE_LEN  120     // max HR readings buffered before drop

// ── Accelerometer (Polar PMD service) ────────────────────────────────────────
#define ACC_SAMPLE_RATE  25      // Hz — must match the PMD start command below (25/50/100/200)
#define ACC_RANGE_G      8       // ±g full-scale
#define ACC_BATCH_MS     2000    // ACC flush interval (ms); 25 Hz → ~50 samples/batch
#define QUEUE_LEN_ACC    256     // max ACC samples buffered before drop
